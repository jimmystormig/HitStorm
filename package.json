{
  "name": "hitstorm",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && npx tsx server/src/index.ts",
    "dev:server": "npx tsx watch server/src/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "npm run build && npx tsx server/src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@playwright/test": "^1.58.2",
    "bonjour-service": "^1.3.0",
    "express": "^5.2.1",
    "node-fetch": "^3.3.0",
    "qrcode.react": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
